{
  "expo": {
    "name": "Horizon Market",
    "slug": "horizon-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "horizonmarket",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unspendablelabs.horizonmarket"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0b15"
      },
      "package": "com.unspendablelabs.horizonmarket"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0b15",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ]
    ]
  }
}
