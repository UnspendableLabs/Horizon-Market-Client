{
  "name": "@unspendablelabs/horizon-market-client",
  "version": "0.2.0",
  "description": "TypeScript client for the Horizon Market Atomic Swap API",
  "keywords": [
    "bitcoin",
    "atomic-swap",
    "counterparty",
    "ordinals",
    "zeld",
    "kontor",
    "psbt",
    "taproot",
    "bip322",
    "marketplace",
    "nft"
  ],
  "license": "MIT",
  "author": "Unspendable Labs",
  "homepage": "https://github.com/UnspendableLabs/Horizon-Market-Client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UnspendableLabs/Horizon-Market-Client.git"
  },
  "bugs": {
    "url": "https://github.com/UnspendableLabs/Horizon-Market-Client/issues"
  },
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/index.cjs"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "react-native": "./dist/react/index.native.js",
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "horizon": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src examples apps/cli/src",
    "format": "prettier --write src",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "expo-clipboard": ">=5.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-svg": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "expo-clipboard": {
      "optional": true
    }
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@kontor/sdk": "^0.3.0-rc.6",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "bip322-js": "^3.0.0",
    "bitcoinjs-lib": "^7.0.1",
    "ecpair": "^3.0.1"
  },
  "devDependencies": {
    "@clack/prompts": "^1.7.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "eslint": "^10.7.0",
    "expo-clipboard": "^7.0.0",
    "jsdom": "^29.1.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.72.0",
    "react-native-svg": "^15.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.10"
  }
}
