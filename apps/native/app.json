{
  "expo": {
    "name": "Horizon Market",
    "slug": "horizon-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "horizonmarket",
    "userInterfaceStyle": "dark",
    "experiments": {
      "tsconfigPaths": false
    },
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unspendablelabs.horizonmarket",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0b15"
      },
      "package": "com.unspendablelabs.horizonmarket",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      "@kontor/sdk-native",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock Horizon Market."
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Use Face ID to unlock your Horizon Market wallet."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0b15",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ],
      "./plugins/withAndroidSecurity.js",
      "./plugins/withGradleMemory.js",
      "expo-font",
      "expo-status-bar",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aa5bd861-640b-4ab2-b298-c23b64b5d02a"
      }
    },
    "owner": "unspendablelabs"
  }
}
