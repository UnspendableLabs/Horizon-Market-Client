{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    // The expo base sets moduleResolution: "node" (node10), which cannot read the
    // SDK's package.json "exports" map, so the "/react" subpath fails to resolve.
    // "bundler" matches how Metro actually resolves it and fixes the typecheck.
    "moduleResolution": "bundler",
    // Resolve the SDK's "react-native" export condition so typecheck uses the
    // native ".native" declarations (e.g. SwapList's `scrollable` prop) — same
    // condition Metro applies at bundle time.
    "customConditions": ["react-native"],
    // Force every `react` import in the program — including the ones inside the
    // file-linked SDK's `.d.ts` — to resolve to THIS app's single @types/react@19.
    // Without this, the SDK (linked via `file:../..`) pulls the repo root's
    // devDep @types/react@18, so React's globals are declared twice and every RN
    // element fails as a JSX component ("bigint not assignable to ReactNode").
    //
    // These `paths` are for TYPECHECK ONLY. Expo's Metro also reads tsconfig
    // `paths` by default, which would redirect the RUNTIME `react` import to
    // `@types/react` (no runtime code → "unable to resolve react"). We disable
    // that in app.json (`expo.experiments.tsconfigPaths: false`); Metro then does
    // its own resolution via metro.config.js (which pins the single React copy),
    // while `tsc` still honours these paths here.
    "baseUrl": ".",
    "paths": {
      "react": ["./node_modules/@types/react"],
      "react/*": ["./node_modules/@types/react/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
