# Horizon Market CLI — environment overrides (all optional).
# Copy to `.env` and `export`/source it, or set the vars inline.

# ─── Keystore + auth ─────────────────────────────────────────────────────────
# Keystore home directory (default: ~/.horizon). Override for a throwaway wallet.
# HORIZON_HOME=/tmp/horizon-signet

# Keystore password. Required in --json / non-TTY mode (no interactive prompt).
# HORIZON_PASSWORD=changeme

# BIP39 passphrase ("25th word"), only if you created the wallet with one.
# HORIZON_PASSPHRASE=

# ─── Network endpoints (mirror the web app's VITE_* vars) ────────────────────
# Mainnet
# HORIZON_MARKET_URL=https://horizon.market
# HORIZON_ORD_API_URL=https://api.counterparty.io:7000
# HORIZON_COUNTERPARTY_API_URL=https://api.counterparty.io:4000
# HORIZON_ZELD_API_URL=https://api.zeldhash.com
# HORIZON_KONTOR_INDEXER_URL=
# HORIZON_KONTOR_NFT_CONTRACT=

# Signet (SDK network = testnet + kontorNetwork = signet)
# HORIZON_MARKET_URL_SIGNET=https://signet.horizon.market
# HORIZON_ORD_API_URL_SIGNET=https://signet.counterparty.io:37000
# HORIZON_COUNTERPARTY_API_URL_SIGNET=https://signet.counterparty.io:34000
# HORIZON_ZELD_API_URL_SIGNET=
# HORIZON_KONTOR_INDEXER_URL_SIGNET=https://signet.kontor.network:35100
# HORIZON_KONTOR_NFT_CONTRACT_SIGNET=
